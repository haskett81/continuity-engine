{
  "name": "continuity-engine",
  "version": "0.3.9",
  "description": "Persistent campaign-state layer for FoundryVTT: threads, clocks, factions, knowledge, and personal-quest debt tracked across sessions.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "node scripts/build.mjs",
    "clean": "node -e \"import('node:fs').then(fs=>fs.rmSync('dist',{recursive:true,force:true}))\"",
    "typecheck": "tsc --noEmit",
    "release": "node scripts/release.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haskett81/continuity-engine.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/haskett81/continuity-engine/issues"
  },
  "homepage": "https://github.com/haskett81/continuity-engine#readme",
  "devDependencies": {
    "@league-of-foundry-developers/foundry-vtt-types": "13.346.0-beta.20250812191140",
    "esbuild": "^0.23.0",
    "typescript": "^5.9.3"
  }
}
