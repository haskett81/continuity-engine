<section class="tab ce-cockpit-tab ce-cockpit-board {{#if tabs.board.active}}active{{/if}}" data-tab="board" data-group="primary">
  <p class="ce-cockpit-session-line">{{localize "CE.common.currentSessionFooter" session=currentSession}}</p>

  {{#if nothingFlagged}}
    <p class="ce-cockpit-empty">{{localize "CE.cockpit.board.nothingFlagged"}}</p>
  {{/if}}

  {{#if staleThreads.length}}
    <h3>{{localize "CE.cockpit.board.staleThreads"}}</h3>
    <ul class="ce-cockpit-list">
      {{#each staleThreads}}
        <li>
          <a data-action="openDoc" data-uuid="{{this.uuid}}">{{this.name}}</a>
          <span class="ce-chip ce-chip--{{this.chip.tone}}">{{this.chip.text}}</span>
        </li>
      {{/each}}
    </ul>
  {{/if}}

  {{#if nearClocks.length}}
    <h3>{{localize "CE.cockpit.board.nearClocks"}}</h3>
    <ul class="ce-cockpit-list">
      {{#each nearClocks}}
        <li>
          <a data-action="openDoc" data-uuid="{{this.uuid}}">{{this.name}}</a>
          <span class="ce-cockpit-note">{{localize "CE.cockpit.board.remaining" n=this.remaining}}</span>
        </li>
      {{/each}}
    </ul>
  {{/if}}

  {{#if beatDebt.length}}
    <h3>{{localize "CE.cockpit.board.beatDebt"}}</h3>
    <ul class="ce-cockpit-list">
      {{#each beatDebt}}
        <li>
          <a data-action="openDoc" data-uuid="{{this.uuid}}">{{this.name}}</a>
          <span class="ce-chip ce-chip--{{this.chip.tone}}">{{this.chip.text}}</span>
        </li>
      {{/each}}
    </ul>
  {{/if}}

  {{#if divergentKnowledge.length}}
    <h3>{{localize "CE.cockpit.board.divergentKnowledge"}}</h3>
    <ul class="ce-cockpit-list">
      {{#each divergentKnowledge}}
        <li>
          <a data-action="openDoc" data-uuid="{{this.uuid}}">{{this.name}}</a>
          <span class="ce-chip ce-chip--{{this.chip.tone}}">{{this.chip.text}}</span>
        </li>
      {{/each}}
    </ul>
  {{/if}}
</section>
