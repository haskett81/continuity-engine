{
  "id": "continuity-engine",
  "title": "Continuity",
  "description": "A persistent campaign-state layer for Foundry. Tracks what is true in the world, what the party believes, what is unresolved, and what is owed to each player character — across sessions, permanently, inside Foundry's own document system.",
  "version": "#{VERSION}#",
  "manifestPlusVersion": "1.2.0",
  "compatibility": {
    "minimum": "14",
    "verified": "14"
  },
  "authors": [
    {
      "name": "haskett81",
      "url": "https://github.com/haskett81"
    }
  ],
  "relationships": {
    "systems": [],
    "requires": []
  },
  "documentTypes": {
    "JournalEntryPage": {
      "thread": {},
      "clock": {},
      "faction": {},
      "knowledge": {},
      "session": {},
      "beat": {}
    }
  },
  "esmodules": [
    "scripts/module.js"
  ],
  "styles": [
    "styles/module.css",
    "styles/sheet.css"
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "url": "#{URL}#",
  "manifest": "#{MANIFEST}#",
  "download": "#{DOWNLOAD}#",
  "license": "LICENSE",
  "readme": "README.md"
}
